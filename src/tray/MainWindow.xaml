<Window x:Class="KVM.Tray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KVM Control Panel" Height="600" Width="900"
        ResizeMode="CanResize" MinWidth="700" MinHeight="500">
    <Grid>
        <TabControl x:Name="MainTabControl">
            <!-- Drivers Tab -->
            <TabItem Header="Drivers">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Driver Control Panel" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Background="#F5F5F5">
                        <StackPanel Margin="15">
                            <!-- Keyboard Driver -->
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="16" Height="16" Fill="Green" x:Name="KeyboardStatus"/>
                                <TextBlock Grid.Column="1" Text="Virtual HID Keyboard" VerticalAlignment="Center" FontSize="14"/>
                                <TextBlock Grid.Column="2" Text="Running" x:Name="KeyboardState" VerticalAlignment="Center"/>
                                <Button Grid.Column="3" Content="Stop" x:Name="KeyboardToggle" Click="KeyboardToggle_Click" Padding="15,5"/>
                            </Grid>
                            
                            <!-- Mouse Driver -->
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="16" Height="16" Fill="Green" x:Name="MouseStatus"/>
                                <TextBlock Grid.Column="1" Text="Virtual HID Mouse" VerticalAlignment="Center" FontSize="14"/>
                                <TextBlock Grid.Column="2" Text="Running" x:Name="MouseState" VerticalAlignment="Center"/>
                                <Button Grid.Column="3" Content="Stop" x:Name="MouseToggle" Click="MouseToggle_Click" Padding="15,5"/>
                            </Grid>
                            
                            <!-- Controller Driver -->
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="16" Height="16" Fill="Gray" x:Name="ControllerStatus"/>
                                <TextBlock Grid.Column="1" Text="Virtual Xbox Controller" VerticalAlignment="Center" FontSize="14"/>
                                <TextBlock Grid.Column="2" Text="Stopped" x:Name="ControllerState" VerticalAlignment="Center"/>
                                <Button Grid.Column="3" Content="Start" x:Name="ControllerToggle" Click="ControllerToggle_Click" Padding="15,5"/>
                            </Grid>
                            
                            <!-- Display Driver -->
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="16" Height="16" Fill="Gray" x:Name="DisplayStatus"/>
                                <TextBlock Grid.Column="1" Text="Virtual Display Monitor" VerticalAlignment="Center" FontSize="14"/>
                                <TextBlock Grid.Column="2" Text="Stopped" x:Name="DisplayState" VerticalAlignment="Center"/>
                                <Button Grid.Column="3" Content="Start" x:Name="DisplayToggle" Click="DisplayToggle_Click" Padding="15,5"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- Logs Tab -->
            <TabItem Header="Logs">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="System Logs" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <ToolBar Grid.Row="1" Margin="0,0,0,5">
                        <Button Content="Clear" Click="ClearLogs_Click"/>
                        <Separator/>
                        <ComboBox x:Name="LogLevelFilter" Width="100" SelectedIndex="0">
                            <ComboBoxItem>All</ComboBoxItem>
                            <ComboBoxItem>Error</ComboBoxItem>
                            <ComboBoxItem>Warning</ComboBoxItem>
                            <ComboBoxItem>Info</ComboBoxItem>
                        </ComboBox>
                        <TextBox x:Name="LogSearch" Width="150" Margin="10,0" ToolTip="Search logs..."/>
                        <Button Content="Export" Click="ExportLogs_Click"/>
                    </ToolBar>
                    
                    <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="LogViewer" IsReadOnly="True" FontFamily="Consolas" 
                                     FontSize="12" TextWrapping="Wrap" Background="#1E1E1E" 
                                     Foreground="#D4D4D4" Padding="10"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- Remote Tab -->
            <TabItem Header="Remote">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Remote Connections" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Server Status: " VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="ServerStatus" Text="Running on port 5900" 
                                   Foreground="Green" VerticalAlignment="Center" FontWeight="Bold"/>
                        <Button Grid.Column="2" Content="Restart Server" Click="RestartServer_Click" Padding="15,5"/>
                    </Grid>
                    
                    <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Active Connections" FontWeight="Bold" Margin="10" FontSize="14"/>
                            <ListView Grid.Row="1" x:Name="ConnectionsList" Margin="10">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Client" Width="150" DisplayMemberBinding="{Binding ClientIP}"/>
                                        <GridViewColumn Header="Type" Width="100" DisplayMemberBinding="{Binding ConnectionType}"/>
                                        <GridViewColumn Header="Connected" Width="120" DisplayMemberBinding="{Binding ConnectTime}"/>
                                        <GridViewColumn Header="Actions" Width="100">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Disconnect" Click="DisconnectClient_Click"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- Settings Tab -->
            <TabItem Header="Settings">
                <ScrollViewer Margin="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Configuration" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

                        <GroupBox Header="VNC Server">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Port:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="VncPort" Text="5900" Width="80" HorizontalAlignment="Left"/>
                                <TextBlock Grid.Row="1" Text="Password:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                                <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="VncPassword" Width="150"
                                             HorizontalAlignment="Left" Margin="0,10,0,0"/>
                                <TextBlock Grid.Row="2" Text="Max Clients:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="VncMaxClients" Text="10" Width="80"
                                         HorizontalAlignment="Left" Margin="0,10,0,0"/>
                                <CheckBox Grid.Row="3" Grid.Column="1" x:Name="VncRequireAuth"
                                          Content="Require Authentication" IsChecked="True" Margin="0,10,0,0"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Native Protocol (WebSocket)" Margin="0,10,0,0">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="WebSocket Port:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="WsPort" Text="8443" Width="80" HorizontalAlignment="Left"/>
                                <TextBlock Grid.Row="1" Text="Max Clients:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="WsMaxClients" Text="20" Width="80"
                                         HorizontalAlignment="Left" Margin="0,10,0,0"/>
                                <CheckBox Grid.Row="2" Grid.Column="1" x:Name="UseTls"
                                          Content="Use TLS/SSL" IsChecked="True" Margin="0,10,0,0"/>
                            </Grid>
                        </GroupBox>

                        <!-- IP Allowlist -->
                        <GroupBox Header="IP Allowlist (one IP or CIDR per line; empty = allow all)" Margin="0,10,0,0">
                            <StackPanel Margin="10">
                                <TextBox x:Name="IpAllowlist" Height="100" AcceptsReturn="True"
                                         FontFamily="Consolas" FontSize="12" VerticalScrollBarVisibility="Auto"
                                         ToolTip="Enter allowed IPs or CIDR ranges, one per line. Empty = allow all connections."/>
                                <TextBlock Text="Example: 192.168.1.0/24 or 10.0.0.5" Foreground="Gray"
                                           FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <StackPanel Orientation="Horizontal" Margin="0,15,0,10">
                            <Button Content="Save Settings" Click="SaveSettings_Click" Padding="20,8" FontSize="14"/>
                            <Button Content="Reset to Defaults" Click="ResetSettings_Click" Padding="20,8"
                                    FontSize="14" Margin="10,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Diagnostics Tab -->
            <TabItem Header="Diagnostics">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="180"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="System Diagnostics" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Run Health Checks" Click="RunDiagnostics_Click"
                                Padding="15,6" Background="#0078D4" Foreground="White" FontWeight="Bold"/>
                        <Button Content="Repair Selected" Click="RepairSelected_Click"
                                Padding="15,6" Margin="10,0,0,0"/>
                        <Button Content="Export Audit Log" Click="ExportAuditLog_Click"
                                Padding="15,6" Margin="10,0,0,0"/>
                        <TextBlock x:Name="DiagStatus" VerticalAlignment="Center"
                                   Margin="15,0,0,0" Foreground="Gray" FontStyle="Italic"/>
                    </StackPanel>

                    <!-- Health check results -->
                    <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1">
                        <ListView x:Name="DiagResultsList" SelectionMode="Single">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="" Width="30" DisplayMemberBinding="{Binding Icon}"/>
                                    <GridViewColumn Header="Check" Width="200" DisplayMemberBinding="{Binding Check}"/>
                                    <GridViewColumn Header="Status" Width="80" DisplayMemberBinding="{Binding SeverityLabel}"/>
                                    <GridViewColumn Header="Message" Width="400" DisplayMemberBinding="{Binding Message}"/>
                                    <GridViewColumn Header="Repair" Width="100" DisplayMemberBinding="{Binding RepairAction}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <TextBlock Grid.Row="3" Text="Connection Audit Log" FontSize="14"
                               FontWeight="Bold" Margin="0,10,0,5"/>

                    <!-- Audit log -->
                    <Border Grid.Row="4" BorderBrush="#CCCCCC" BorderThickness="1">
                        <ListView x:Name="AuditLogList">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Time" Width="150" DisplayMemberBinding="{Binding TimestampStr}"/>
                                    <GridViewColumn Header="Client IP" Width="120" DisplayMemberBinding="{Binding ClientIP}"/>
                                    <GridViewColumn Header="Protocol" Width="80" DisplayMemberBinding="{Binding Protocol}"/>
                                    <GridViewColumn Header="Event" Width="130" DisplayMemberBinding="{Binding EventType}"/>
                                    <GridViewColumn Header="Details" Width="300" DisplayMemberBinding="{Binding Details}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
